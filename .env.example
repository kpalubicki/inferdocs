# Application Settings
APP_ENV=dev
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM Backend Configuration
LLM_BACKEND=ollama
LLM_MODEL=default

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# vLLM Configuration
VLLM_BASE_URL=http://localhost:8000

# Document Storage
DOCUMENTS_DIR=./data/documents
METADATA_FILE=./data/metadata.json

# Logging
LOG_LEVEL=INFO
